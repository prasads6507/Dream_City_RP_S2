rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is any staff member
    function isStaff() {
      return request.auth != null && 
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role in ['admin', 'police', 'ems', 'mechanic'];
    }

    // Whitelist Applications
    match /whitelistApplications/{applicationId} {
      // Authenticated users can create a new application
      allow create: if request.auth != null;
      
      // Staff can read all applications, authenticated users can read their own
      // Note: Current client-side logic fetches all and filters, so we allow read for staff
      allow read: if request.auth != null;
      
      // Admin and department staff can update or delete applications
      allow update, delete: if isStaff();
    }

    
    // Users Profile
    match /Users/{userId} {
      // Only the user themselves can read/write their profile
      // Or staff can read profiles
      allow read: if request.auth != null && (request.auth.uid == userId || isStaff());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Approved Players (FiveM Sync)
    match /approvedPlayers/{discordId} {
      // Only staff can manage the sync collection
      allow read, write: if isStaff();
    }

    // System Settings (Global UI Locks)
    match /System/{document=**} {
      // Anyone can read Global UI Locks
      allow read: if true;
      
      // Only admins can update the locks (Department leads shouldn't lock the portal)
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
