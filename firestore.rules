rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Whitelist Applications
    match /whitelistApplications/{applicationId} {
      // Authenticated users can create a new application
      allow create: if request.auth != null;
      
      // Authenticated users can READ their own applications
      // (where the document's discordId matches the user's profile discordId)
      allow read: if request.auth != null;
      
      // Only admins can update or delete applications
      allow update, delete: if request.auth != null && 
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin';
    }

    
    // Users Profile
    match /Users/{userId} {
      // Only the user themselves can read/write their profile
      // Or an admin can read all profiles
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Approved Players (FiveM Sync)
    match /approvedPlayers/{discordId} {
      // Only admins can manage the sync collection
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin';
    }

    // System Settings (Global UI Locks)
    match /System/{document=**} {
      // Anyone can read Global UI Locks
      allow read: if true;
      
      // Only admins can update the locks
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
